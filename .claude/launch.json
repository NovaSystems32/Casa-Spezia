{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "casa-spezia",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const h=require('http'),fs=require('fs'),p=require('path');h.createServer((q,r)=>{let f=p.join('C:/Users/secundario/Desktop/casa-spezia',q.url==='/'?'index.html':q.url);try{const d=fs.readFileSync(f);const m={'html':'text/html','css':'text/css','js':'application/javascript'};r.writeHead(200,{'Content-Type':m[f.split('.').pop()]||'text/plain'});r.end(d)}catch(e){r.writeHead(404);r.end('Not found')}}).listen(3000)"],
      "port": 3000
    }
  ]
}
